# ============================================================
# ShiftMaster-py  —  Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=shift_py
DB_PASSWORD=               # REQUIRED — no default
DB_NAME=shift_master_py_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=50
DB_MIN_CONNS=10

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=                # REQUIRED — must be >= 32 chars, generated securely
JWT_ISSUER=shiftmaster-py
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7
JWT_BCRYPT_COST=12

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENV=development     # development | production
SERVER_WORKERS=2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (pydantic parses JSON arrays)
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_LOGIN_MAX_ATTEMPTS=5
REDIS_LOGIN_WINDOW_SECONDS=300

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_BASE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# ── RabbitMQ (Phase 1) ────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
